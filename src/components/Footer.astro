---
// src/components/Footer.astro
---

<footer class="bg-canvas border-t border-hairline py-16 px-6">
  <div
    class="max-w-[1200px] mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-8"
  >
    <!-- Col 1: Brand Info -->
    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <img
          src="https://res.cloudinary.com/dyo3ckrjq/image/upload/v1782469077/logo_folw2r.png"
          alt="Zcompressor Logo"
          class="w-6 h-6 rounded-sm select-none"
        />
        <span
          class="font-sans font-semibold text-base text-ink tracking-[-0.4px]"
          >Zcompressor</span
        >
      </div>
      <p class="text-caption text-body">
        A premium, high-security developer-grade utility to compress PDFs
        locally in your browser.
      </p>
    </div>

    <!-- Col 2: Product -->
    <div>
      <h4
        class="text-caption-mono font-mono text-mute uppercase tracking-wider mb-4"
      >
        Product
      </h4>
      <ul class="space-y-2">
        <li>
          <a
            href="/#compressor"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >Compressor</a
          >
        </li>
        <li>
          <a
            href="/#features"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >Features</a
          >
        </li>
        <li>
          <a
            href="/#faq"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >FAQ</a
          >
        </li>
      </ul>
    </div>

    <!-- Col 3: Company -->
    <div>
      <h4
        class="text-caption-mono font-mono text-mute uppercase tracking-wider mb-4"
      >
        Company
      </h4>
      <ul class="space-y-2">
        <li>
          <a
            href="/about"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >About Us</a
          >
        </li>
        <li>
          <a
            href="/contact"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >Contact Us</a
          >
        </li>
        <li>
          <a
            href="/privacy"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >Privacy Policy</a
          >
        </li>
        <li>
          <a
            href="/terms"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >Terms & Conditions</a
          >
        </li>
      </ul>
    </div>

    <!-- Col 4: Resources -->
    <div>
      <h4
        class="text-caption-mono font-mono text-mute uppercase tracking-wider mb-4"
      >
        Resources
      </h4>
      <ul class="space-y-2">
        <li>
          <a
            href="https://pdf-lib.js.org/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >pdf-lib docs</a
          >
        </li>
        <li>
          <a
            href="https://mozilla.github.io/pdf.js/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-body-sm text-body hover:text-ink transition-colors"
            >pdf.js docs</a
          >
        </li>
      </ul>
    </div>

    <!-- Col 5: Security -->
    <div>
      <h4
        class="text-caption-mono font-mono text-mute uppercase tracking-wider mb-4"
      >
        Security
      </h4>
      <ul class="space-y-2">
        <li>
          <span class="text-body-sm text-body flex items-center gap-1.5"
            ><i class="fa-solid fa-lock text-xs text-cyan-deep"></i> 100% Local Sandbox</span
          >
        </li>
        <li>
          <span class="text-body-sm text-body flex items-center gap-1.5"
            ><i class="fa-solid fa-network-wired text-xs text-mute"></i> No telemetry
            / logs sent</span
          >
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom Copyright Bar -->
  <div
    class="max-w-[1200px] mx-auto mt-12 pt-8 border-t border-hairline/60 flex flex-col sm:flex-row justify-between items-center gap-4"
  >
    <span class="text-caption text-mute">
      © 2026 Zcompressor. Open Source under MIT License.
    </span>
    <div class="flex gap-4">
      <a
        href="/terms"
        class="text-caption text-mute hover:text-ink transition-colors"
        >Terms & Conditions</a
      >
      <a
        href="/privacy"
        class="text-caption text-mute hover:text-ink transition-colors"
        >Privacy Policy</a
      >
    </div>
  </div>
</footer>
