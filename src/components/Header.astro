---
// src/components/Header.astro
---

<!-- Navigation Bar -->
<nav
  class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md px-6 py-2 transition-all"
>
  <div
    class="max-w-[1200px] mx-auto h-[48px] flex items-center justify-between"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 group rounded focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      aria-label="Zcompress Homepage"
    >
      <img
        src="https://res.cloudinary.com/dyo3ckrjq/image/upload/v1782469077/logo_folw2r.png"
        alt="Zcompress Logo"
        class="w-8 h-8 rounded-sm select-none group-hover:scale-105 transition-transform duration-200"
      />
      <span class="font-sans font-semibold text-lg text-ink tracking-[-0.6px]"
        >Zcompress</span
      >
    </a>

    <!-- Navigation Links -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/#faq"
        class="text-body-sm text-body hover:text-ink transition-colors px-3 py-1.5 rounded-full hover:bg-canvas-soft-2/50 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
        >FAQ</a
      >
      <a
        href="/about"
        class="text-body-sm text-body hover:text-ink transition-colors px-3 py-1.5 rounded-full hover:bg-canvas-soft-2/50 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
        >About Us</a
      >
      <a
        href="/contact"
        class="text-body-sm text-body hover:text-ink transition-colors px-3 py-1.5 rounded-full hover:bg-canvas-soft-2/50 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
        >Contact Us</a
      >
      <a
        href="/privacy"
        class="text-body-sm text-body hover:text-ink transition-colors px-3 py-1.5 rounded-full hover:bg-canvas-soft-2/50 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none animate-fade-in"
        >Privacy Policy</a
      >
      <a
        href="/terms"
        class="text-body-sm text-body hover:text-ink transition-colors px-3 py-1.5 rounded-full hover:bg-canvas-soft-2/50 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none animate-fade-in"
        >Terms & Conditions</a
      >
    </div>

    <!-- Action Button -->
    <div class="flex items-center gap-3">
      <span
        class="hidden sm:inline-flex items-center gap-1.5 px-2.5 py-1 text-[11px] font-mono border border-hairline rounded bg-canvas-soft text-body"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"
          aria-hidden="true"></span>
        100% Client-Side
      </span>

      <!-- Theme Toggle Button -->
      <button
        id="theme-toggle"
        class="w-[28px] h-[28px] rounded-sm border border-hairline bg-canvas text-ink flex items-center justify-center hover:bg-canvas-soft-2/50 cursor-pointer transition-colors shadow-level-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
        aria-label="Toggle theme"
      >
        <i
          class="fa-regular fa-sun hidden dark:block text-xs"
          aria-hidden="true"></i>
        <i
          class="fa-regular fa-moon block dark:hidden text-xs"
          aria-hidden="true"></i>
      </button>

      <a
        href="/#compressor"
        class="px-3.5 h-[28px] bg-primary text-on-primary text-body-sm-strong rounded-sm hover:bg-black transition-colors inline-flex items-center justify-center select-none shadow-level-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >
        Start Compressing
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1.5 text-body hover:text-ink transition-colors rounded focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
        aria-label="Toggle Navigation Menu"
      >
        <i class="fa-solid fa-bars text-xl" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-hairline mt-2 py-4 flex flex-col gap-3 animate-fade-in"
  >
    <a
      href="/#faq"
      class="mobile-nav-link text-body hover:text-ink transition-colors py-2 border-b border-hairline/30 text-body-sm-strong focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >FAQ</a
    >
    <a
      href="/about"
      class="mobile-nav-link text-body hover:text-ink transition-colors py-2 border-b border-hairline/30 text-body-sm-strong focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >About Us</a
    >
    <a
      href="/contact"
      class="mobile-nav-link text-body hover:text-ink transition-colors py-2 border-b border-hairline/30 text-body-sm-strong focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >Contact Us</a
    >
    <a
      href="/privacy"
      class="mobile-nav-link text-body hover:text-ink transition-colors py-2 border-b border-hairline/30 text-body-sm-strong focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >Privacy Policy</a
    >
    <a
      href="/terms"
      class="mobile-nav-link text-body hover:text-ink transition-colors py-2 text-body-sm-strong focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >Terms & Conditions</a
    >
    <div
      class="flex sm:hidden items-center justify-between pt-2 border-t border-hairline/30"
    >
      <span
        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-[11px] font-mono border border-hairline rounded bg-canvas-soft text-body"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"
          aria-hidden="true"></span>
        100% Client-Side
      </span>
    </div>
  </div>
</nav>

<script>
  // Theme Toggle Handler
  const themeToggle = document.getElementById("theme-toggle");
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }

  // Mobile Menu Toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener("click", () => {
      const isHidden = mobileMenu.classList.contains("hidden");
      if (isHidden) {
        mobileMenu.classList.remove("hidden");
        mobileMenuBtn.querySelector("i").className =
          "fa-solid fa-xmark text-xl";
      } else {
        mobileMenu.classList.add("hidden");
        mobileMenuBtn.querySelector("i").className =
          "fa-solid fa-bars text-xl";
      }
    });

    // Close mobile menu when clicking nav links
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        mobileMenuBtn.querySelector("i").className =
          "fa-solid fa-bars text-xl";
      });
    });
  }
</script>
