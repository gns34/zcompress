---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="500: Internal Error - Zcompress"
  description="An unexpected error occurred while running the local PDF compressor pipeline."
  ogUrl="https://zcompress.com/500"
>
  <Header />

  <main class="min-h-[80vh] flex items-center justify-center bg-canvas-soft text-ink py-16 px-6 relative overflow-hidden">
    <!-- Ambient Background Mesh Gradient with slightly warning/pink tones -->
    <div class="absolute inset-0 bg-mesh-gradient opacity-35 dark:opacity-20 pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-[1000px] w-full mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
      
      <!-- Text/Content Area (7 cols on large, full on small) -->
      <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-warning/20 bg-warning-soft/30 text-warning-deep dark:text-amber-400 font-mono text-xs w-fit mx-auto lg:mx-0">
          <span class="w-2 h-2 rounded-full bg-warning animate-pulse"></span>
          Error 500
        </div>
        
        <h1 class="text-display-lg sm:text-display-xl font-semibold tracking-[-1.5px] md:tracking-[-2.4px] leading-tight text-ink">
          Pipeline execution crash.
        </h1>
        
        <p class="text-body-lg text-body max-w-[550px] mx-auto lg:mx-0">
          An unexpected error occurred while processing requests. Since Zcompress runs 100% locally in your browser, this might be due to a browser memory limitation or script timeout.
        </p>

        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 pt-4">
          <button
            onclick="window.location.reload()"
            class="px-6 h-[40px] bg-primary text-on-primary text-body-sm-strong rounded-pill hover:bg-black dark:hover:bg-neutral-200 transition-all duration-200 inline-flex items-center justify-center shadow-level-2 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none select-none cursor-pointer"
          >
            Reload Pipeline
          </button>
          <a
            href="/"
            class="px-6 h-[40px] bg-canvas text-ink border border-hairline text-body-sm-strong rounded-pill hover:bg-canvas-soft-2 transition-all duration-200 inline-flex items-center justify-center shadow-level-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none select-none cursor-pointer"
          >
            Go to Homepage
          </a>
        </div>
      </div>

      <!-- Terminal Mockup (5 cols on large, full on small) -->
      <div class="lg:col-span-5 w-full max-w-[450px] mx-auto lg:mx-0">
        <div class="bg-[#121212] text-[#f5f5f5] rounded-lg border border-[#222222] overflow-hidden shadow-level-4 font-mono text-xs select-none">
          <!-- Terminal Header -->
          <div class="bg-[#171717] border-b border-[#222222] px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-error-deep"></span>
              <span class="w-3 h-3 rounded-full bg-warning"></span>
              <span class="w-3 h-3 rounded-full bg-cyan-deep"></span>
            </div>
            <span class="text-white/40 text-[10px] uppercase font-mono tracking-widest">zcompress-terminal</span>
            <div class="w-10"></div>
          </div>
          <!-- Terminal Body -->
          <div class="p-5 space-y-3 min-h-[220px]">
            <div class="flex gap-2">
              <span class="text-cyan-deep font-bold">$</span>
              <span id="typing-command" class="text-white border-r-2 border-white pr-0.5 animate-pulse">zcompress </span>
            </div>
            <div id="terminal-output" class="space-y-2 text-white/50">
              <p id="term-line-1" class="opacity-0 transition-opacity duration-300">Initializing PDF.js local worker threads...</p>
              <p id="term-line-2" class="opacity-0 text-cyan-deep flex items-center gap-2 transition-opacity duration-300">
                <i class="fa-solid fa-circle-check" aria-hidden="true"></i> Allocation sandbox: OK.
              </p>
              <p id="term-line-3" class="opacity-0 text-error-soft flex items-center gap-2 font-semibold transition-opacity duration-300">
                <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> Critical: WebAssembly context out of memory.
              </p>
              <div id="term-line-4" class="opacity-0 border-t border-[#222222] my-2 pt-2 text-[10px] text-white/30 flex justify-between">
                <span>SANDBOX: FAULT</span>
                <span>STATUS: CRASHED</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Simple terminal typing effect simulation
  const cmdElement = document.getElementById('typing-command');
  const line1 = document.getElementById('term-line-1');
  const line2 = document.getElementById('term-line-2');
  const line3 = document.getElementById('term-line-3');
  const line4 = document.getElementById('term-line-4');

  if (cmdElement) {
    const text = 'zcompress --execute-local-pipeline';
    cmdElement.textContent = '$ '; // Start with Prompt
    let i = 2; // Start index after prompt
    
    function typeWriter() {
      if (i < text.length) {
        cmdElement.textContent = '$ ' + text.substring(2, i + 1);
        i++;
        setTimeout(typeWriter, 30 + Math.random() * 20);
      } else {
        // Remove cursor pulsing borders once typing ends
        cmdElement.classList.remove('border-r-2', 'border-white', 'pr-0.5');
        showTerminalOutput();
      }
    }
    
    function showTerminalOutput() {
      // Cascade display of terminal messages
      setTimeout(() => {
        if (line1) line1.classList.replace('opacity-0', 'opacity-100');
      }, 300);

      setTimeout(() => {
        if (line2) line2.classList.replace('opacity-0', 'opacity-100');
      }, 900);

      setTimeout(() => {
        if (line3) line3.classList.replace('opacity-0', 'opacity-100');
      }, 1500);

      setTimeout(() => {
        if (line4) line4.classList.replace('opacity-0', 'opacity-100');
      }, 2100);
    }
    
    // Start typing after a short delay
    setTimeout(typeWriter, 600);
  }
</script>
