---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact Us - Zcompressor | Get in Touch"
  description="Contact Zcompressor. Submit feedback, ask questions, or report bugs regarding our client-side online PDF compressor."
  ogUrl="https://Zcompressor.com/contact"
>
  <Header />

  <main class="min-h-screen bg-canvas-soft text-ink py-16 px-6">
    <div class="max-w-[1000px] mx-auto">
      <!-- Page Header -->
      <div class="mb-12 border-b border-hairline pb-8 text-center sm:text-left">
        <span
          class="text-caption-mono font-mono text-link-deep uppercase tracking-wider block mb-3"
        >
          Get in Touch
        </span>
        <h1
          class="text-display-lg md:text-display-xl text-ink font-semibold tracking-[-1.5px] md:tracking-[-2.4px] mb-4"
        >
          Contact Us.
        </h1>
        <p class="text-body-lg text-body max-w-[600px]">
          Have questions about security, suggestions for improvements, or bug
          reports? We'd love to hear from you.
        </p>
      </div>

      <!-- Two Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact Form Column (3/5) -->
        <div class="lg:col-span-3 space-y-6">
          <div
            class="bg-canvas border border-hairline rounded-lg p-6 sm:p-8 shadow-level-3"
          >
            <h2
              class="text-display-sm text-ink font-semibold tracking-[-0.6px] mb-6"
            >
              Send a Message
            </h2>

            <!-- Form -->
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label
                    for="contact-name"
                    class="text-body-sm-strong text-ink"
                  >
                    Name
                  </label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    required
                    placeholder="Jane Doe"
                    class="w-full h-[40px] bg-canvas text-ink border border-hairline rounded-sm px-3 text-body-sm focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-all"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    for="contact-email"
                    class="text-body-sm-strong text-ink"
                  >
                    Email
                  </label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    required
                    placeholder="jane@example.com"
                    class="w-full h-[40px] bg-canvas text-ink border border-hairline rounded-sm px-3 text-body-sm focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-all"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label
                  for="contact-subject"
                  class="text-body-sm-strong text-ink"
                >
                  Subject
                </label>
                <input
                  type="text"
                  id="contact-subject"
                  name="subject"
                  required
                  placeholder="Bug Report, Feature Request, Feedback..."
                  class="w-full h-[40px] bg-canvas text-ink border border-hairline rounded-sm px-3 text-body-sm focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-all"
                />
              </div>

              <div class="space-y-2">
                <label
                  for="contact-message"
                  class="text-body-sm-strong text-ink"
                >
                  Message
                </label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Type your message here..."
                  class="w-full bg-canvas text-ink border border-hairline rounded-sm p-3 text-body-sm focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-all resize-y min-h-[120px]"
                ></textarea>
              </div>

              <button
                type="submit"
                id="contact-submit-btn"
                class="w-full h-[44px] bg-primary text-on-primary text-body-sm-strong rounded-pill hover:bg-black transition-all flex items-center justify-center select-none shadow-level-2 hover:scale-[1.01] duration-200 cursor-pointer focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
              >
                Send Message
              </button>
            </form>

            <!-- Success Alert State -->
            <div
              id="contact-success"
              class="hidden space-y-4 text-center py-6 animate-fade-in"
            >
              <div
                class="w-12 h-12 mx-auto bg-cyan-soft border border-cyan-deep/20 text-cyan-deep rounded-full flex items-center justify-center text-xl shadow-level-2"
              >
                <i class="fa-solid fa-circle-check"></i>
              </div>
              <div class="space-y-1">
                <h3 class="text-body-md-strong text-ink">
                  Thank you for your message!
                </h3>
                <p class="text-body-sm text-body">
                  Your feedback has been logged in browser console sandbox
                  simulation. We will review it shortly.
                </p>
              </div>
              <button
                id="contact-reset-btn"
                class="px-4 py-2 bg-canvas text-ink border border-hairline text-body-sm-strong rounded-pill hover:bg-canvas-soft transition-colors cursor-pointer focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
              >
                Send Another Message
              </button>
            </div>
          </div>
        </div>

        <!-- Info / Details Column (2/5) -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Support Card -->
          <div
            class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2 space-y-4"
          >
            <h3 class="text-body-md-strong text-ink flex items-center gap-2">
              <i class="fa-solid fa-envelope text-link-deep"></i> Direct Support
            </h3>
            <p class="text-body-sm text-body leading-relaxed">
              Prefer emailing directly? Our core team monitors support issues on
              weekdays.
            </p>
            <a
              href="mailto:support@Zcompressor.com"
              class="text-body-sm text-link hover:underline font-mono inline-block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded"
            >
              support@Zcompressor.com
            </a>
          </div>

          <!-- Open Source Card -->
          <div
            class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2 space-y-4"
          >
            <h3 class="text-body-md-strong text-ink flex items-center gap-2">
              <i class="fa-brands fa-github text-primary dark:text-white"></i> Open
              Source Issues
            </h3>
            <p class="text-body-sm text-body leading-relaxed">
              Zcompressor is 100% open-source. For technical bugs, feature
              requests, or direct contributions, please open a GitHub Issue.
            </p>
            <a
              href="https://github.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-body-sm text-link hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded"
            >
              Go to GitHub Repository <i
                class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
            </a>
          </div>

          <!-- Safety Notice Card -->
          <div
            class="bg-canvas-soft-2 border border-hairline rounded-lg p-6 shadow-level-1 space-y-3"
          >
            <h4
              class="text-caption-mono font-mono text-mute uppercase tracking-wider block"
            >
              100% Local Sandbox Notice
            </h4>
            <p class="text-body-sm text-body leading-relaxed">
              Any files you drag and drop into the homepage compressor remain
              inside your browser sandbox. The contact form on this page only
              transmits metadata text fields you submit here, never any files or
              documents.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const contactForm = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const contactSuccess = document.getElementById("contact-success");
  const contactResetBtn = document.getElementById("contact-reset-btn");

  if (contactForm && contactSuccess) {
    contactForm.addEventListener("submit", (e) => {
      e.preventDefault();

      // Simulate form submission
      contactForm.classList.add("hidden");
      contactSuccess.classList.remove("hidden");

      // Log simulated form contents
      const formData = new FormData(contactForm);
      console.log("[Simulation] Form Submitted successfully:", {
        name: formData.get("name"),
        email: formData.get("email"),
        subject: formData.get("subject"),
        message: formData.get("message"),
      });
    });
  }

  if (contactResetBtn && contactForm && contactSuccess) {
    contactResetBtn.addEventListener("click", () => {
      contactForm.reset();
      contactSuccess.classList.add("hidden");
      contactForm.classList.remove("hidden");
    });
  }
</script>
