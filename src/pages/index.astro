  <!-- Core Javascript Compression Logic -->
  <script>
    // Helper to dynamically load external scripts
    function loadScript(src) {
      return new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = src;
        script.async = true;
        script.onload = resolve;
        script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
        document.body.appendChild(script);
      });
    }

    let librariesPromise = null;
    function loadLibraries() {
      if (librariesPromise) return librariesPromise;

      librariesPromise = Promise.all([
        loadScript("https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"),
        loadScript("https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"),
        loadScript("https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js")
      ]).then(() => {
        if (window.pdfjsLib) {
          window.pdfjsLib.GlobalWorkerOptions.workerSrc =
            "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
        }
      });
      return librariesPromise;
    }

    // Trigger background loading after page load or on first interaction
    window.addEventListener("load", () => {
      if ("requestIdleCallback" in window) {
        requestIdleCallback(() => setTimeout(loadLibraries, 1000));
      } else {
        setTimeout(loadLibraries, 1500);
      }
    });

    const triggerEvents = ["dragover", "click", "touchstart"];
    function triggerLoad() {
      loadLibraries();
      triggerEvents.forEach(evt => document.removeEventListener(evt, triggerLoad));
    }
    triggerEvents.forEach(evt => document.addEventListener(evt, triggerLoad, { passive: true }));

    // Program State
    let queue = [];
    let isProcessing = false;
    let selectedPreset = "1mb";
    let customTargetSize = 1000; // KB

    // DOM Elements
    const dropzone = document.getElementById("dropzone");
    const fileInput = document.getElementById("file-input");
    const queueContainer = document.getElementById("queue-container");
    const queueList = document.getElementById("queue-list");
    const queueBadge = document.getElementById("queue-badge");
    const totalInputSizeEl = document.getElementById("total-input-size");
    const totalSavingsContainer = document.getElementById(
      "total-savings-container",
    );
    const totalOutputSizeEl = document.getElementById("total-output-size");
    const totalSavingsPctEl = document.getElementById("total-savings-pct");
    const compressBtn = document.getElementById("compress-btn");
    const downloadZipBtn = document.getElementById("download-zip-btn");
    const clearQueueBtn = document.getElementById("clear-queue-btn");
    const terminalLogs = document.getElementById("terminal-logs");
    const clearLogsBtn = document.getElementById("clear-logs-btn");
    const presetButtons = document.querySelectorAll(".preset-btn");
    const customSliders = document.getElementById("custom-sliders");
    const sizeSlider = document.getElementById("size-slider");
    const sizeVal = document.getElementById("size-val");

    // Collapsible Terminal Elements
    const terminalHeader = document.getElementById("terminal-header");
    const terminalToggleIcon = document.getElementById("terminal-toggle-icon");

    // Terminal Logger
    function logToConsole(message, type = "info") {
      const timestamp = new Date().toTimeString().split(" ")[0];
      const div = document.createElement("div");

      let prefix = "[INFO]";
      let colorClass = "text-white";

      if (type === "sys") {
        prefix = "[SYS]";
        colorClass = "text-white/40";
      } else if (type === "success") {
        prefix = "[OK]";
        colorClass = "text-cyan-soft";
      } else if (type === "error") {
        prefix = "[ERR]";
        colorClass = "text-highlight-pink font-semibold";
      } else if (type === "progress") {
        prefix = "[COMPRESS]";
        colorClass = "text-warning-soft";
      }

      div.className = colorClass;
      div.innerHTML = `<span class="opacity-60">${timestamp}</span> ${prefix} ${message}`;
      terminalLogs.appendChild(div);
      terminalLogs.scrollTop = terminalLogs.scrollHeight;
    }

    // Size Formatter
    function formatBytes(bytes, decimals = 2) {
      if (bytes === 0) return "0 Bytes";
      const k = 1024;
      const dm = decimals < 0 ? 0 : decimals;
      const sizes = ["Bytes", "KB", "MB", "GB"];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + " " + sizes[i];
    }

    // Setup Presets Configuration
    function getTargetSize() {
      if (selectedPreset === "250kb") {
        return 250 * 1024;
      } else if (selectedPreset === "500kb") {
        return 500 * 1024;
      } else if (selectedPreset === "1mb") {
        return 1 * 1024 * 1024;
      } else if (selectedPreset === "2mb") {
        return 2 * 1024 * 1024;
      } else if (selectedPreset === "5mb") {
        return 5 * 1024 * 1024;
      } else if (selectedPreset === "custom") {
        return customTargetSize * 1024;
      } else {
        return 1 * 1024 * 1024; // Default to 1MB
      }
    }

    // Event Listeners for Preset buttons
    presetButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        presetButtons.forEach((b) => {
          b.classList.remove(
            "active",
            "border-2",
            "border-primary",
            "bg-canvas-soft",
          );
          b.classList.add("border", "border-hairline");
        });

        btn.classList.remove("border", "border-hairline");
        btn.classList.add(
          "active",
          "border-2",
          "border-primary",
          "bg-canvas-soft",
        );

        selectedPreset = btn.getAttribute("data-preset");

        if (selectedPreset === "custom") {
          customSliders.classList.remove("hidden");
        } else {
          customSliders.classList.add("hidden");
        }

        const targetSize = getTargetSize();
        logToConsole(
          `Preset changed to: ${selectedPreset.toUpperCase()} (Target Size: ${formatBytes(targetSize)})`,
          "sys",
        );
      });
    });

    // Custom Slider Input Listener
    sizeSlider.addEventListener("input", (e) => {
      customTargetSize = parseInt(e.target.value);
      sizeVal.textContent = `${customTargetSize} KB (${(customTargetSize / 1024).toFixed(1)} MB)`;
    });

    // FAQ Accordion Handler
    document.querySelectorAll(".faq-item button").forEach((button) => {
      button.addEventListener("click", () => {
        const item = button.parentElement;
        const answer = item.querySelector(".faq-answer");
        const icon = button.querySelector("i");

        if (answer.style.maxHeight) {
          answer.style.maxHeight = null;
          icon.style.transform = "rotate(0deg)";
          button.setAttribute("aria-expanded", "false");
        } else {
          // close other open accordions
          document.querySelectorAll(".faq-item button").forEach((btn) => {
            const ans = btn.parentElement.querySelector(".faq-answer");
            ans.style.maxHeight = null;
            btn.parentElement.querySelector("i").style.transform =
              "rotate(0deg)";
            btn.setAttribute("aria-expanded", "false");
          });
          answer.style.maxHeight = answer.scrollHeight + "px";
          icon.style.transform = "rotate(180deg)";
          button.setAttribute("aria-expanded", "true");
        }
      });
    });

    // Clear Console Logs
    clearLogsBtn.addEventListener("click", () => {
      terminalLogs.innerHTML = `<div class="text-mute">[SYS] Console cleared. ready.</div>`;
    });

    // Terminal Collapse Toggle
    if (terminalHeader && terminalLogs && terminalToggleIcon) {
      const toggleTerminal = () => {
        const isHidden = terminalLogs.classList.contains("hidden");
        if (isHidden) {
          terminalLogs.classList.remove("hidden");
          terminalToggleIcon.style.transform = "rotate(0deg)";
          terminalHeader.setAttribute("aria-expanded", "true");
        } else {
          terminalLogs.classList.add("hidden");
          terminalToggleIcon.style.transform = "rotate(-90deg)";
          terminalHeader.setAttribute("aria-expanded", "false");
        }
      };

      terminalHeader.addEventListener("click", (e) => {
        if (e.target.closest("#clear-logs-btn")) return;
        toggleTerminal();
      });

      terminalHeader.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          toggleTerminal();
        }
      });

      // Collapse terminal by default on mobile screens
      if (window.innerWidth < 768) {
        terminalLogs.classList.add("hidden");
        terminalToggleIcon.style.transform = "rotate(-90deg)";
        terminalHeader.setAttribute("aria-expanded", "false");
      }
    }

    // Handling Drag and Drop / Selection
    function addFilesToQueue(files) {
      if (isProcessing) {
        logToConsole("Cannot add files while compression is running.", "error");
        return;
      }

      let addedCount = 0;
      for (const file of files) {
        if (file.type !== "application/pdf") {
          logToConsole(`Skipped non-PDF file: ${file.name}`, "error");
          continue;
        }

        // Prevent duplicate loads
        if (
          queue.some(
            (item) =>
              item.file.name === file.name && item.file.size === file.size,
          )
        ) {
          continue;
        }

        const id = "file-" + Math.random().toString(36).substr(2, 9);
        queue.push({
          id,
          file,
          status: "pending",
          progress: 0,
          compressedSize: null,
          compressedBlob: null,
        });
        addedCount++;
        logToConsole(
          `Added file to queue: ${file.name} (${formatBytes(file.size)})`,
          "sys",
        );
      }

      if (addedCount > 0) {
        updateQueueUI();
      }
    }

    fileInput.addEventListener("change", (e) => {
      addFilesToQueue(e.target.files);
      fileInput.value = ""; // Reset input to allow choosing the same file again
    });

    // Drag-over styling
    ["dragenter", "dragover"].forEach((eventName) => {
      dropzone.addEventListener(
        eventName,
        (e) => {
          e.preventDefault();
          dropzone.classList.add("border-primary", "bg-canvas-soft-2");
        },
        false,
      );
    });

    ["dragleave", "drop"].forEach((eventName) => {
      dropzone.addEventListener(
        eventName,
        (e) => {
          e.preventDefault();
          dropzone.classList.remove("border-primary", "bg-canvas-soft-2");
        },
        false,
      );
    });

    dropzone.addEventListener("drop", (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      addFilesToQueue(files);
    });

    // Update the Queue UI Elements
    function updateQueueUI() {
      if (queue.length === 0) {
        queueContainer.classList.add("hidden");
        return;
      }

      queueContainer.classList.remove("hidden");
      queueBadge.textContent = queue.length;

      queueList.innerHTML = "";
      let totalInputSize = 0;
      let totalOutputSize = 0;
      let completedCount = 0;

      queue.forEach((item) => {
        totalInputSize += item.file.size;

        const row = document.createElement("div");
        row.className =
          "py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3";
        row.id = item.id;

        let statusBadge = `<span class="px-2 py-0.5 text-[11px] rounded bg-canvas-soft text-body border border-hairline font-mono">Pending</span>`;
        let progressSection = "";
        let statsSection = `<span class="text-body-sm font-mono text-body">${formatBytes(item.file.size)}</span>`;
        let actionButton = `<button onclick="window.removeQueueItem('${item.id}')" class="text-mute hover:text-error-deep p-1 transition-colors rounded focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none" aria-label="Remove file from queue"><i class="fa-regular fa-trash-can" aria-hidden="true"></i></button>`;

        if (item.status === "compressing") {
          statusBadge = `<span class="px-2 py-0.5 text-[11px] rounded bg-warning-soft text-warning-deep border border-warning-deep/10 font-mono animate-pulse">Compressing</span>`;
          progressSection = `
            <div class="w-full bg-hairline rounded-full h-1.5 mt-2 overflow-hidden">
              <div class="bg-gradient-to-r from-gradient-develop-start to-gradient-develop-end h-1.5 rounded-full transition-all duration-150" style="width: ${item.progress}%"></div>
            </div>
          `;
          actionButton = `<span class="text-[11px] font-mono text-mute">${item.progress}%</span>`;
        } else if (item.status === "completed") {
          const savingsPct = Math.round(
            ((item.file.size - item.compressedSize) / item.file.size) * 100,
          );
          totalOutputSize += item.compressedSize;
          completedCount++;

          statusBadge = `<span class="px-2 py-0.5 text-[11px] rounded bg-link-bg-soft text-success border border-link/10 font-mono">Completed</span>`;
          statsSection = `
            <div class="text-right">
              <div class="text-body-sm font-mono text-mute line-through">${formatBytes(item.file.size)}</div>
              <div class="text-body-sm font-mono font-medium text-success">${formatBytes(item.compressedSize)} <span class="font-semibold">(-${savingsPct}%)</span></div>
            </div>
          `;

          actionButton = `
            <button onclick="window.downloadSingleItem('${item.id}')" class="px-2.5 py-1 bg-primary text-on-primary rounded hover:bg-black text-[11px] font-semibold transition-all inline-flex items-center gap-1 shadow-level-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none">
              <i class="fa-solid fa-download" aria-hidden="true"></i> Download
            </button>
          `;
        } else if (item.status === "failed") {
          statusBadge = `<span class="px-2 py-0.5 text-[11px] rounded bg-error-soft text-error-deep border border-error/10 font-mono">Failed</span>`;
          actionButton = `<span class="text-[11px] text-error-deep"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> Error</span>`;
        }

        row.innerHTML = `
          <div class="flex items-center gap-3 min-w-0 w-full sm:max-w-[65%]">
            <i class="fa-regular fa-file-pdf text-xl text-body flex-shrink-0" aria-hidden="true"></i>
            <div class="truncate min-w-0 w-full">
              <div class="text-body-sm-strong text-ink truncate">${item.file.name}</div>
              <div class="flex items-center gap-2 mt-1">
                ${statusBadge}
                ${progressSection}
              </div>
            </div>
          </div>
          <div class="flex items-center justify-between sm:justify-end gap-6 w-full sm:w-auto">
            ${statsSection}
            <div class="w-20 text-right flex-shrink-0 flex justify-end">
              ${actionButton}
            </div>
          </div>
        `;
        queueList.appendChild(row);
      });

      totalInputSizeEl.textContent = formatBytes(totalInputSize);

      if (completedCount > 0) {
        totalSavingsContainer.classList.remove("hidden");
        totalOutputSizeEl.textContent = formatBytes(totalOutputSize);
        const totalSavingsPct = Math.round(
          ((totalInputSize - totalOutputSize) / totalInputSize) * 100,
        );
        totalSavingsPctEl.textContent = `-${totalSavingsPct}%`;
        downloadZipBtn.classList.remove("hidden");
      } else {
        totalSavingsContainer.classList.add("hidden");
        downloadZipBtn.classList.add("hidden");
      }
    }

    // Expose Global UI Functions
    window.removeQueueItem = function (id) {
      if (isProcessing) return;
      queue = queue.filter((item) => item.id !== id);
      logToConsole("Removed item from queue.", "sys");
      updateQueueUI();
    };

    window.downloadSingleItem = function (id) {
      const item = queue.find((i) => i.id === id);
      if (!item || !item.compressedBlob) return;

      const url = URL.createObjectURL(item.compressedBlob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `compressed_${item.file.name}`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    };

    // Clean Queue Button
    clearQueueBtn.addEventListener("click", () => {
      if (isProcessing) return;
      queue = [];
      logToConsole("Queue cleared.", "sys");
      updateQueueUI();
    });

    // ZIP Download Button
    downloadZipBtn.addEventListener("click", async () => {
      await loadLibraries();
      const completedItems = queue.filter(
        (item) => item.status === "completed" && item.compressedBlob,
      );
      if (completedItems.length === 0) return;

      logToConsole("Creating ZIP archive containing compressed files…", "sys");

      const zip = new JSZip();
      completedItems.forEach((item) => {
        zip.file(`compressed_${item.file.name}`, item.compressedBlob);
      });

      try {
        const zipBlob = await zip.generateAsync({ type: "blob" });
        const url = URL.createObjectURL(zipBlob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "Zcompressored_pdfs.zip";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        logToConsole(
          "ZIP archive successfully generated and downloaded.",
          "success",
        );
      } catch (err) {
        logToConsole(`Failed to create ZIP: ${err.message}`, "error");
      }
    });

    // The core PDF compression wrapper loop
    compressBtn.addEventListener("click", async () => {
      if (isProcessing) return;
      const pendingItems = queue.filter((item) => item.status !== "completed");
      if (pendingItems.length === 0) {
        logToConsole("No pending files in the queue to compress.", "error");
        return;
      }

      isProcessing = true;
      compressBtn.disabled = true;
      compressBtn.classList.add("opacity-50", "cursor-not-allowed");
      clearQueueBtn.disabled = true;
      clearQueueBtn.classList.add("opacity-50", "cursor-not-allowed");

      const targetSize = getTargetSize();
      logToConsole(
        `Starting batch compression queue. Target Size: ${formatBytes(targetSize)}`,
        "sys",
      );

      for (const item of pendingItems) {
        item.status = "compressing";
        item.progress = 0;
        updateQueueUI();
        logToConsole(`Initializing compression for: ${item.file.name}`, "sys");

        try {
          const compressedBytes = await runCompressEngine(
            item.file,
            targetSize,
            (pageNum, totalPages, passNum) => {
              item.progress = Math.round((pageNum / totalPages) * 100);
              updateQueueUI();
              logToConsole(
                `[Pass ${passNum}] Compressed Page ${pageNum}/${totalPages} for ${item.file.name}…`,
                "progress",
              );
            },
          );

          item.status = "completed";
          item.compressedSize = compressedBytes.length;
          item.compressedBlob = new Blob([compressedBytes], {
            type: "application/pdf",
          });

          const reduction = Math.round(
            ((item.file.size - item.compressedSize) / item.file.size) * 100,
          );
          logToConsole(
            `Compression completed for ${item.file.name}. Saved ${reduction}% (New size: ${formatBytes(item.compressedSize)})`,
            "success",
          );
        } catch (err) {
          console.error(err);
          item.status = "failed";
          logToConsole(
            `Compression failed for ${item.file.name}: ${err.message}`,
            "error",
          );
        }

        updateQueueUI();
      }

      isProcessing = false;
      compressBtn.disabled = false;
      compressBtn.classList.remove("opacity-50", "cursor-not-allowed");
      clearQueueBtn.disabled = false;
      clearQueueBtn.classList.remove("opacity-50", "cursor-not-allowed");
      logToConsole("Batch compression queue finished.", "sys");
    });

    // Helper to render and compress pages in a single pass
    async function runSingleCompressPass(pdfDoc, totalPages, dpi, quality, onProgress, passNum) {
      const newPdfDoc = await window.PDFLib.PDFDocument.create();
      const canvas = document.createElement("canvas");
      const context = canvas.getContext("2d");

      for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
        const page = await pdfDoc.getPage(pageNum);
        let scale = dpi / 72; // pdf.js default is 72 dpi
        let viewport = page.getViewport({ scale });

        // Safety limit to prevent high DPI and large page canvas allocations from crashing mobile browsers (OOM)
        const MAX_CANVAS_DIMENSION = 3000;
        if (
          viewport.width > MAX_CANVAS_DIMENSION ||
          viewport.height > MAX_CANVAS_DIMENSION
        ) {
          const limitScale =
            MAX_CANVAS_DIMENSION / Math.max(viewport.width, viewport.height);
          scale = scale * limitScale;
          viewport = page.getViewport({ scale });
        }

        canvas.width = viewport.width;
        canvas.height = viewport.height;

        context.fillStyle = "#ffffff";
        context.fillRect(0, 0, canvas.width, canvas.height);

        await page.render({ canvasContext: context, viewport }).promise;

        const imgDataUrl = canvas.toDataURL("image/jpeg", quality);
        const jpegImage = await newPdfDoc.embedJpg(imgDataUrl);

        const originalWidth = viewport.width / scale;
        const originalHeight = viewport.height / scale;
        const newPage = newPdfDoc.addPage([originalWidth, originalHeight]);

        newPage.drawImage(jpegImage, {
          x: 0,
          y: 0,
          width: originalWidth,
          height: originalHeight,
        });

        if (onProgress) {
          onProgress(pageNum, totalPages, passNum);
        }
      }

      canvas.width = 0;
      canvas.height = 0;

      return await newPdfDoc.save();
    }

    // The low level execution code doing Canvas rendering & PDF injection
    async function runCompressEngine(file, targetSize, onProgress) {
      await loadLibraries();
      if (!window.pdfjsLib || !window.PDFLib) {
        throw new Error(
          "Required libraries (pdf.js or pdf-lib) failed to initialize.",
        );
      }

      const arrayBuffer = await file.arrayBuffer();
      const originalBytes = new Uint8Array(arrayBuffer);

      // Check if original file is already smaller than target size.
      // If so, return original directly to preserve 100% quality.
      if (originalBytes.length <= targetSize) {
        logToConsole(`Original file size (${formatBytes(originalBytes.length)}) is already under the target limit of ${formatBytes(targetSize)}. Returning original file directly to preserve 100% quality.`, "success");
        return originalBytes;
      }

      const pdfDoc = await window.pdfjsLib.getDocument({ data: arrayBuffer.slice(0) })
        .promise;
      const totalPages = pdfDoc.numPages;

      logToConsole(`File has ${totalPages} pages. Target size is ${formatBytes(targetSize)}.`, "sys");

      // Heuristic for starting parameters based on target size per page
      const targetSizePerPage = targetSize / totalPages;
      const kbPerPage = targetSizePerPage / 1024;
      
      let dpi = 150;
      let quality = 0.65;

      if (kbPerPage >= 1000) {
        dpi = 300;
        quality = 0.9;
      } else if (kbPerPage >= 500) {
        dpi = 220;
        quality = 0.85;
      } else if (kbPerPage >= 250) {
        dpi = 180;
        quality = 0.8;
      } else if (kbPerPage >= 120) {
        dpi = 150;
        quality = 0.7;
      } else if (kbPerPage >= 60) {
        dpi = 120;
        quality = 0.6;
      } else {
        dpi = 90;
        quality = 0.5;
      }

      logToConsole(`Pass 1: Estimating parameters (DPI: ${dpi}, Quality: ${Math.round(quality * 100)}%)`, "sys");

      let compressedBytes = await runSingleCompressPass(pdfDoc, totalPages, dpi, quality, onProgress, 1);
      let resultingSize = compressedBytes.length;

      logToConsole(`Pass 1 result size: ${formatBytes(resultingSize)}`, "sys");

      // If resulting size exceeds target size, try to adjust and run a 2nd pass
      if (resultingSize > targetSize && (dpi > 60 || quality > 0.15)) {
        const ratio = targetSize / resultingSize;
        const safetyRatio = ratio * 0.92; // Conservative 8% safety buffer to force target size compliance

        const oldDpi = dpi;
        const oldQuality = quality;

        // Try to reduce quality first to preserve resolution (DPI)
        let newQuality = oldQuality * safetyRatio;
        let newDpi = oldDpi;

        if (newQuality < 0.35) {
          // If quality drops below 0.35, cap it and reduce DPI instead
          const remainingRatio = newQuality / 0.35;
          newQuality = 0.35;
          newDpi = Math.max(60, Math.min(300, Math.round(oldDpi * Math.sqrt(remainingRatio))));
        } else {
          newQuality = Math.max(0.35, Math.min(0.9, newQuality));
        }

        dpi = newDpi;
        quality = newQuality;

        logToConsole(`Result size exceeds target. Adjusting parameters for Pass 2: DPI ${oldDpi} -> ${dpi}, Quality ${Math.round(oldQuality * 100)}% -> ${Math.round(quality * 100)}%`, "sys");

        compressedBytes = await runSingleCompressPass(pdfDoc, totalPages, dpi, quality, onProgress, 2);
        resultingSize = compressedBytes.length;
        logToConsole(`Pass 2 result size: ${formatBytes(resultingSize)}`, "sys");
      }

      // If resulting size STILL exceeds target size after Pass 2, try to adjust and run an emergency 3rd pass
      if (resultingSize > targetSize && (dpi > 50 || quality > 0.15)) {
        const ratio = targetSize / resultingSize;
        const safetyRatio = ratio * 0.88; // Even more conservative 12% safety buffer for the final pass

        const oldDpi = dpi;
        const oldQuality = quality;

        // For Pass 3, aggressively reduce both parameters to ensure compliance
        dpi = Math.max(50, Math.min(300, Math.round(oldDpi * Math.sqrt(safetyRatio))));
        quality = Math.max(0.15, Math.min(0.8, oldQuality * safetyRatio));

        logToConsole(`Result size STILL exceeds target. Aggressively adjusting parameters for final Pass 3: DPI ${oldDpi} -> ${dpi}, Quality ${Math.round(oldQuality * 100)}% -> ${Math.round(quality * 100)}%`, "sys");

        compressedBytes = await runSingleCompressPass(pdfDoc, totalPages, dpi, quality, onProgress, 3);
        resultingSize = compressedBytes.length;
        logToConsole(`Pass 3 result size: ${formatBytes(resultingSize)}`, "sys");
      }

      // If the original file size was already smaller than our best compression result,
      // or if compression actually made the file larger than the original, return original.
      if (originalBytes.length < resultingSize) {
        logToConsole(`Compressed size (${formatBytes(resultingSize)}) is larger than original file (${formatBytes(originalBytes.length)}). Returning original file to preserve quality.`, "sys");
        return originalBytes;
      }

      return compressedBytes;
    }
  </script>
</Layout>
